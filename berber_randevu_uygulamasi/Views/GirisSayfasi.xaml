<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="berber_randevu_uygulamasi.Views.GirisSayfasi"
             BackgroundColor="#0F0F0F">

    <VerticalStackLayout Padding="30" Spacing="20"
                         VerticalOptions="Center"
                         HorizontalOptions="Center">

        <Label Text="💈 Elrin Barber"
               FontSize="32"
               FontAttributes="Bold"
               TextColor="#F2F2F2"
               HorizontalOptions="Center"/>

        <Entry x:Name="kullaniciAdiEntry"
               Placeholder="Kullanıcı Adı"
               PlaceholderColor="#B5B5B5"
               FontSize="18"
               HeightRequest="50"
               Completed="KullaniciAdiEntry_Completed"
               BackgroundColor="#1C1C1C"
               TextColor="#F2F2F2"
               Margin="0,10,0,0"
               WidthRequest="250"/>

        <Entry x:Name="SifreEntry"
               Placeholder="Şifre"
               IsPassword="True"
               PlaceholderColor="#B5B5B5"
               FontSize="18"
               HeightRequest="50"
               Completed="SifreEntry_Completed"
               BackgroundColor="#1C1C1C"
               TextColor="#F2F2F2"
               WidthRequest="250"/>

        <Button Text="Giriş Yap"
                BackgroundColor="#FF8A00"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="18"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="GirisYap_Clicked"
                WidthRequest="250"/>

        <Label Text="Hesabın yok mu?"
               HorizontalOptions="Center"
               FontSize="16"
               TextColor="#B5B5B5"/>

        <Label Text="Kayıt Ol"
               TextColor="#A57C50"
               FontAttributes="Bold"
               FontSize="18"
               HorizontalOptions="Center"
               x:Name="KayitOlLabel"
               VerticalOptions="Center">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="KayitOl_Tapped"/>
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>
</ContentPage>
