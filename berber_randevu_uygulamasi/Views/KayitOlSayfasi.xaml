<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="berber_randevu_uygulamasi.Views.KayitOlSayfasi"
             BackgroundColor="#0F0F0F"
             Title="Kayıt Ol">

    <ScrollView>
        <VerticalStackLayout Padding="20,80"
                             Spacing="25"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">

            <!-- Kart -->
            <Border BackgroundColor="#1A1A1A"
                    Stroke="#2B2B2B"
                    StrokeShape="RoundRectangle 20"
                    Padding="25"
                    WidthRequest="330">

                <VerticalStackLayout Spacing="18">

                    <!-- Başlık -->
                    <Label Text="Kayıt Ol"
                           FontSize="26"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#F2F2F2" />

                    <!-- Ad -->
                    <Entry x:Name="AdEntry"
                           Placeholder="Ad"
                           TextColor="#F2F2F2"
                           PlaceholderColor="#777"
                           BackgroundColor="#232323"
                           HeightRequest="45" />

                    <!-- Soyad -->
                    <Entry x:Name="SoyadEntry"
                           Placeholder="Soyad"
                           TextColor="#F2F2F2"
                           PlaceholderColor="#777"
                           BackgroundColor="#232323"
                           HeightRequest="45" />

                    <!-- Kullanıcı Adı -->
                    <Entry x:Name="KullaniciAdiEntry"
                           Placeholder="Kullanıcı Adı"
                           TextColor="#F2F2F2"
                           PlaceholderColor="#777"
                           BackgroundColor="#232323"
                           HeightRequest="45" />

                    <!-- E-posta -->
                    <Entry x:Name="EmailEntry"
                           Placeholder="E-posta"
                           Keyboard="Email"
                           TextColor="#F2F2F2"
                           PlaceholderColor="#777"
                           BackgroundColor="#232323"
                           HeightRequest="45" />

                    <!-- Şifre -->
                    <Entry x:Name="SifreEntry"
                           Placeholder="Şifre"
                           IsPassword="True"
                           TextColor="#F2F2F2"
                           PlaceholderColor="#777"
                           BackgroundColor="#232323"
                           HeightRequest="45" />

                    <!-- Telefon -->
                    <Entry x:Name="TelefonEntry"
                           Placeholder="Telefon (05xx xxx xx xx)"
                           Keyboard="Telephone"
                           MaxLength="20"
                           TextColor="#F2F2F2"
                           PlaceholderColor="#777"
                           BackgroundColor="#232323"
                           HeightRequest="45" />

                    <!-- Kayıt Ol Butonu -->
                    <Button Text="Kayıt Ol"
                            BackgroundColor="#FF8A00"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="20"
                            HeightRequest="45"
                            Clicked="KayitOl_Clicked"/>

                    <!-- Giriş Yap -->
                    <Label Text="Zaten hesabın var mı? Giriş Yap"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="#AAAAAA">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GirisYap_Tapped"/>
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>