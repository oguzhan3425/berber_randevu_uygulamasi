<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="Sayfa"
    x:Class="berber_randevu_uygulamasi.Views.RandevuOlusturSayfasi"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:berber_randevu_uygulamasi.Views"
    x:DataType="local:RandevuOlusturVM"
    Title="Randevu Oluştur"
    BackgroundColor="#0F0F0F">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ÜST BAR -->
        <Grid Padding="12,10" ColumnDefinitions="Auto,*">
            <ImageButton Source="back.png"
                         WidthRequest="28"
                         HeightRequest="28"
                         BackgroundColor="Transparent"
                         Clicked="Geri_Clicked" />
            <Label Grid.Column="1"
                   Text="Randevu Oluştur"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#F2F2F2"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="12" Spacing="14">

                <!-- ÇALIŞAN KARTI -->
                <Border Stroke="#262626"
                        StrokeThickness="1"
                        BackgroundColor="#151515"
                        Padding="14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="70,*" ColumnSpacing="14" VerticalOptions="Center">
                        <!-- Foto -->
                        <Border HeightRequest="60"
                                WidthRequest="60"
                                BackgroundColor="#222222"
                                StrokeThickness="0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30" />
                            </Border.StrokeShape>
                            <Image Source="{Binding CalisanFoto}" Aspect="AspectFill"/>
                        </Border>

                        <!-- İsim -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding CalisanAdSoyad}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#F2F2F2"/>
                            <Label Text="Berber / Stylist"
                                   FontSize="13"
                                   TextColor="#BDBDBD"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- TARİH SEÇİMİ -->
                <Label Text="Randevu Tarihi"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#F2F2F2"
                       Margin="2,6,0,0"/>

                <Border Stroke="#262626"
                        StrokeThickness="1"
                        BackgroundColor="#151515"
                        Padding="12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                        <Label Text="Tarih"
                               TextColor="#BDBDBD"
                               VerticalOptions="Center"/>

                        <DatePicker x:Name="dateTarih"
                                    Grid.Column="1"
                                    TextColor="#F2F2F2"
                                    BackgroundColor="#111111"
                                    DateSelected="dateTarih_DateSelected"/>
                    </Grid>
                </Border>

                <!-- SAAT / DAKİKA SEÇİMİ -->
                <Label Text="Randevu Saati"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#F2F2F2"
                       Margin="2,6,0,0"/>

                <Border Stroke="#262626"
                        StrokeThickness="1"
                        BackgroundColor="#151515"
                        Padding="12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <!-- Saat Picker -->
                            <Picker x:Name="pickerSaat"
                                    Grid.Column="0"
                                    Title="Saat"
                                    TextColor="#F2F2F2"
                                    BackgroundColor="#111111"/>

                            <!-- Dakika Picker -->
                            <Picker x:Name="pickerDakika"
                                    Grid.Column="1"
                                    Title="Dakika (5 dk)"
                                    TextColor="#F2F2F2"
                                    BackgroundColor="#111111"/>
                        </Grid>

                        <Label x:Name="lblSecimOzeti"
                               Text=""
                               FontSize="12"
                               TextColor="#8E8E8E" />
                    </VerticalStackLayout>
                </Border>

                <!-- HİZMET SEÇİMİ -->
                <Label Text="Hizmet Seçimi"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#F2F2F2"
                       Margin="2,6,0,0"/>

                <CollectionView ItemsSource="{Binding Hizmetler}"
                                SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:HizmetItem">
                            <Border Margin="0,6"
                                    Padding="12"
                                    BackgroundColor="{Binding KartRenk}"
                                    Stroke="#262626"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18"/>
                                </Border.StrokeShape>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Hizmet_Tapped"
                      CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                    <!-- checkbox -->
                                    <Border HeightRequest="22" WidthRequest="22" StrokeThickness="1" Stroke="#3A3A3A" BackgroundColor="#111111">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Check}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               TextColor="#F2F2F2"
                                               FontSize="14"
                                               FontAttributes="Bold"/>
                                    </Border>

                                    <!-- ad + süre -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Ad}"
                                               FontSize="15"
                                               TextColor="#F2F2F2"
                                               VerticalOptions="Center" />
                                        <Label Text="{Binding SureDakika, StringFormat='{0} dk'}"
                                               FontSize="12"
                                               TextColor="#8E8E8E"
                                               VerticalOptions="Center" />
                                    </VerticalStackLayout>

                                    <!-- fiyat -->
                                    <Label Grid.Column="2"
                                           Text="{Binding FiyatText}"
                                           FontSize="15"
                                           TextColor="#BDBDBD"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BUTON -->
        <Border Grid.Row="2"
                Padding="12"
                BackgroundColor="#0F0F0F">
            <Button Text="Randevu Oluştur"
                    CornerRadius="18"
                    BackgroundColor="#1B1B1B"
                    TextColor="#F2F2F2"
                    HeightRequest="52"
                    Clicked="RandevuOlustur_Clicked"/>
        </Border>

    </Grid>
</ContentPage>